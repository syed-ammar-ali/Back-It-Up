<!-- landing.ejs -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Back It Up</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Poppins", sans-serif;
      }
    </style>
  </head>
  <body>
    <div
      class="h-screen bg-cover bg-center flex flex-col justify-center items-center text-center gap-20"
      style="background-image: url('../images/main.jpg')"
    >
      <h1 class="text-7xl font-bold text-black mb-10 ml-10 mr-10 uppercase">
        Everything you need, right where you left it.
      </h1>
      <div class="flex justify-center items-center space-x-5">
        <a
          href="/user/login"
          class="bg-blue-500 hover:bg-blue-800 text-white text-md font-semibold py-3 px-7 rounded-full"
          >Login</a
        >
        <h1 class="text-md font-semibold text-white">or</h1>
        <a
          href="/user/register"
          class="bg-green-500 hover:bg-green-800 text-white text-md font-semibold py-3 px-7 rounded-full"
          >Register</a
        >
      </div>
    </div>
  </body>
</html>
